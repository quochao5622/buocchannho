{
    "name": "quochao56/equipment",
    "description": "Equipment management plugin for Filament",
    "keywords": [
        "quochao56",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "equipment"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Hảo Lê",
            "email": "thomaszen63@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/tables": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "autoload": {
        "psr-4": {
            "Quochao56\\Equipment\\": "src/",
            "Quochao56\\Equipment\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Quochao56\\Equipment\\EquipmentServiceProvider"
            ],
            "aliases": {
                "Equipment": "Quochao56\\Equipment\\Facades\\Equipment"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

