{
    "name": "quochao56/session-log",
    "description": "Daily logs and behavior incident logging for special education children.",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "quochao56/core": "*@dev",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "autoload": {
        "psr-4": {
            "Quochao56\\SessionLog\\": "src/",
            "Quochao56\\SessionLog\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Quochao56\\SessionLog\\SessionLogServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
