{
    "name": "quochao56/core",
    "description": "Shared core utilities for Quochao56 packages",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "autoload": {
        "psr-4": {
            "Quochao56\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Quochao56\\Core\\CoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
